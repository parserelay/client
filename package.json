{
  "name": "@parserelay/client",
  "version": "0.1.0",
  "description": "Thin REST client for the ParseRelay scan API.",
  "license": "MIT",
  "homepage": "https://parserelay.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parserelay/client.git"
  },
  "bugs": { "url": "https://github.com/parserelay/client/issues" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@parserelay/core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
